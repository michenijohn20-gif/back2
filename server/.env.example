DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
JWT_SECRET="change-me-long-random-string"
JWT_REFRESH_SECRET="change-me-refresh-secret"

ADMIN_JWT_SECRET="change-me-admin-bearer-secret"

# Comma-separated allowed origins (your Netlify URL + local dev)
CLIENT_URL=https://your-app.netlify.app,http://localhost:5173

# SMTP (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="RefurbKE <orders@refurb.ke>"
ADMIN_NOTIFICATION_EMAIL=admin@yourcompany.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# M-Pesa Daraja
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://YOUR-RAILWAY-URL.up.railway.app/api/payments/mpesa/callback
SERVER_PUBLIC_URL=https://YOUR-RAILWAY-URL.up.railway.app

# Paystack card payments
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CURRENCY=KES
PAYSTACK_WEBHOOK_URL=https://YOUR-RAILWAY-URL.up.railway.app/api/payments/paystack/webhook

# Admin product autofill (MobileAPI.dev)
MOBILEAPI_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
